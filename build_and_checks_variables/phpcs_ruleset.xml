<?xml version="1.0"?>
<ruleset name="LFBFLCustomStandard" namespace="LFBFL\CS\CustomStandard">
  <description>A custom coding standard</description>
  <config name="tab_width" value="2"/>

  <file>../</file>

  <arg name="extensions" value="php"/>
  <arg name="report" value="summary"/>
  <arg name="colors"/>
  <arg value="sp"/>

  <!--
  I added all the standards, then excluded all the rules that gave me
  false positives or that seemed unappropriate when looking at the
  documentation.
  Some are bugs, some are conflicting with my own coding style.
  You may delete an exclude and see what pops up to maybe understand
  my choices.
  -->

  <rule ref="Generic">
    <!-- You have to allow long or short or both syntaxes. -->
    <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
    <exclude name="Generic.Commenting.DocComment.ParamGroup"/>
    <exclude name="Generic.Commenting.DocComment.TagsNotGrouped"/>
    <exclude name="Generic.Commenting.DocComment.TagValueIndent"/>
    <!-- Back to my habits at Teliae with always a closing tag. -->
    <!-- <exclude name="Generic.PHP.ClosingPHPTag.NotFound"/> -->
    <!--
    Not standard in Unix/Linux world to keep files not ending with \n.
    This is always an option of the code editors.
    Since PHP doesn't output the final \n after ?>, it is ok.
    -->
    <exclude name="Generic.Files.EndFileNoNewline.Found"/>
    <exclude name="Generic.Files.ExecutableFile.Executable"/>
    <exclude name="Generic.Formatting.MultipleStatementAlignment"/>
    <exclude
     name="Generic.Functions.OpeningFunctionBraceBsdAllman.BraceOnSameLine"
    />
    <exclude
      name="Generic.NamingConventions.CamelCapsFunctionName.NotCamelCaps"
    />
    <!-- Applies only to true, false and null. -->
    <exclude name="Generic.PHP.LowerCaseConstant.Found"/>
    <exclude name="Generic.PHP.UpperCaseConstant.Found"/>
    <!-- const_bidule_HTML_truc would be better. Everything is prefix. -->
    <exclude name="Generic.WhiteSpace.DisallowSpaceIndent.SpacesUsed"/>
  </rule>
  <rule ref="PEAR">
    <exclude name="PEAR.Commenting.FileComment.MissingVersion"/>
    <exclude name="PEAR.Commenting.FileComment.MissingLinkTag"/>
    <!--
    Look at the comment before generate_split_score.
    PEAR and Squiz require to align the parameter names parts in the same
    comment, and also the parameter comments parts in the same comment,
    but with a long parameter name like $a_delimiter_strings_domain
    and a line length limit at 75 characters, parameter comments parts
    have only 24 characters left per line, which is ridiculous.
    Our choice to put the parameter comments parts starting on another line
    with same "indent" as parameter names parts is way better in those
    cases. Alignment has always been a trap with short lines.
    Since phpDocumentor handles the parameter comments parts correctly,
    it is enough for me.
    Worse is the handling of "nested doc block comment" for the Closure
    returned by generate_split_score().
    Our solution makes at least the source code readable.
    Maybe one day the dev tools will handle it correctly.
    -->
    <exclude name="PEAR.Commenting.FunctionComment.DuplicateReturn"/>
    <exclude name="PEAR.Commenting.FunctionComment.ExtraParamComment"/>
    <exclude name="PEAR.Commenting.FunctionComment.MissingParamComment"/>
    <exclude name="PEAR.Commenting.FunctionComment.SpacingAfterParamName"/>
    <exclude name="PEAR.Commenting.FunctionComment.SpacingAfterParamType"/>
    <exclude name="PEAR.ControlStructures.ControlSignature.Found"/>
    <exclude name="PEAR.ControlStructures.MultiLineCondition.Alignment"/>
    <exclude
      name="PEAR.ControlStructures.MultiLineCondition.SpaceBeforeOpenBrace"
    />
    <exclude
     name="PEAR.ControlStructures.MultiLineCondition.SpacingAfterOpenBrace"
    />
    <exclude
      name="PEAR.ControlStructures.MultiLineCondition.StartWithBoolean"
    />
    <!--
    Don't laugh when looking at the false positives of the two exclude
    below ;) XD.
    They don't check for multiline function declarations apparently.
    -->
    <exclude
      name="PEAR.Functions.FunctionDeclaration.NewlineBeforeOpenBrace"
    />
    <exclude
      name="PEAR.Functions.FunctionDeclaration.BraceOnSameLine"
    />
    <exclude
      name="PEAR.NamingConventions.ValidFunctionName.FunctionNoCapital"
    />
    <exclude
      name="PEAR.NamingConventions.ValidFunctionName.FunctionNameInvalid"
    />
  </rule>
  <rule ref="PSR1">
  </rule>
  <rule ref="PSR2">
    <!-- Back to my habits at Teliae with always a closing tag. -->
    <exclude name="PSR2.Files.ClosingTag.NotAllowed"/>
    <exclude
name="PSR2.ControlStructures.ControlStructureSpacing.SpacingAfterOpenBrace"
    />
  </rule>
  <rule ref="PSR12">
    <exclude
 name="PSR12.ControlStructures.ControlStructureSpacing.FirstExpressionLine"
    />
    <exclude name="PSR12.Files.FileHeader.SpacingAfterDeclareBlock"/>
    <!--
    3 false positives, see:
    https://github.com/PHPCSStandards/PHP_CodeSniffer/issues/1402
    -->
    <exclude
      name="PSR12.Files.DeclareStatement.SpaceFoundAfterDirectiveValue"
    />
    <exclude
      name="PSR12.Files.DeclareStatement.SpaceFoundBeforeDirectiveValue"
    />
    <exclude
      name="PSR12.Files.DeclareStatement.SpaceFoundBeforeSemicolon"
    />
    <!-- and even a fourth and fifth false positives -->
    <exclude
      name="PSR12.Files.DeclareStatement.CloseBracketNotAligned"
    />
    <exclude
      name="PSR12.Files.DeclareStatement.ExtraSpaceFoundAfterBracket"
    />
    <exclude name="PSR12.Classes.ClosingBrace.StatementAfter"/>
    <exclude
      name="PSR12.Functions.ReturnTypeDeclaration.SpaceBeforeColon"
    />
    <exclude name="PSR2.Namespaces.NamespaceDeclaration.BlankLineAfter"/>
    <exclude name="PSR2.Namespaces.UseDeclaration.SpaceAfterLastUse"/>
    <!-- I agree except for string concatenation. -->
    <exclude name="PSR12.Operators.OperatorSpacing.NoSpaceBefore"/>
    <exclude name="PSR12.Operators.OperatorSpacing.NoSpaceAfter"/>
  </rule>
  <rule ref="Squiz">
    <exclude name="Squiz.Arrays.ArrayDeclaration.SingleLineNotAllowed"/>
    <!--
    It doesn't know the //*/ trick...
    https://github.com/PHPCSStandards/PHP_CodeSniffer/issues/1403
    -->
    <exclude name="Squiz.Commenting.BlockComment.CloserSameLine"/>
    <exclude name="Squiz.Commenting.BlockComment.FirstLineIndent"/>
    <exclude name="Squiz.Commenting.BlockComment.LineIndent"/>
    <exclude name="Squiz.Commenting.BlockComment.NoCapital"/>
    <exclude name="Squiz.Commenting.BlockComment.NoEmptyLineAfter"/>
    <exclude name="Squiz.Commenting.BlockComment.NoEmptyLineBefore"/>
    <!-- Problem for doc block comment before namespace -->
    <exclude name="Squiz.Commenting.BlockComment.WrongStart"/>
    <exclude name="Squiz.Commenting.DocCommentAlignment.SpaceBeforeStar"/>
    <exclude name="Squiz.Commenting.FileComment.CopyrightTagOrder"/>
    <exclude name="Squiz.Commenting.FileComment.IncorrectAuthor"/>
    <exclude name="Squiz.Commenting.FileComment.IncorrectCopyright"/>
    <exclude name="Squiz.Commenting.FileComment.MissingSubpackageTag"/>
    <exclude name="Squiz.Commenting.FileComment.PackageTagOrder"/>
    <exclude name="Squiz.Commenting.FileComment.SpacingAfterOpen"/>
    <exclude name="Squiz.Commenting.FileComment.SubpackageTagOrder"/>
    <exclude name="Squiz.Commenting.FunctionComment.DuplicateReturn"/>
    <exclude name="Squiz.Commenting.FunctionComment.ExtraParamComment"/>
    <!-- asks for boolean instead of bool which is incorrect -->
    <exclude
      name="Squiz.Commenting.FunctionComment.IncorrectParamVarName"
    />
    <!-- asks for boolean instead of bool which is incorrect -->
    <exclude name="Squiz.Commenting.FunctionComment.InvalidReturn"/>
    <exclude name="Squiz.Commenting.FunctionComment.MissingParamComment"/>
    <exclude name="Squiz.Commenting.FunctionComment.ParamCommentFullStop"/>
    <exclude
      name="Squiz.Commenting.FunctionComment.SpacingAfterParamName"
    />
    <exclude
      name="Squiz.Commenting.FunctionComment.SpacingAfterParamType"
    />
    <!-- Problem for doc block comment before namespace -->
    <exclude name="Squiz.Commenting.InlineComment.DocBlock"/>
    <exclude name="Squiz.Commenting.InlineComment.NotCapital"/>
    <!-- It doesn't know the //*/ trick... -->
    <exclude name="Squiz.Commenting.InlineComment.NoSpaceBefore"/>
    <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
    <exclude name="Squiz.Commenting.LongConditionClosingComment.Invalid"/>
    <exclude name="Squiz.Commenting.PostStatementComment.Found"/>
    <exclude
      name="Squiz.ControlStructures.ControlSignature.SpaceAfterCloseBrace"
    />
    <exclude
 name="Squiz.ControlStructures.ControlSignature.SpaceAfterCloseParenthesis"
    />
    <exclude
      name="Squiz.ControlStructures.ControlSignature.SpaceAfterKeyword"
    />
    <exclude name="Squiz.Formatting.OperatorBracket.MissingBrackets"/>
    <exclude name="Squiz.Functions.GlobalFunction.Found"/>
    <exclude
      name="Squiz.Functions.MultiLineFunctionDeclaration.BraceOnSameLine"
    />
    <exclude
 name="Squiz.Functions.MultiLineFunctionDeclaration.NewlineBeforeOpenBrace"
    />
    <exclude
      name="Squiz.NamingConventions.ValidFunctionName.NotCamelCaps"
    />
    <exclude
      name="Squiz.NamingConventions.ValidVariableName.NotCamelCaps"
    />
    <exclude name="Squiz.Operators.ComparisonOperatorUsage.NotAllowed"/>
    <exclude name="Squiz.Operators.ComparisonOperatorUsage.ImplicitTrue"/>
    <exclude name="Squiz.PHP.CommentedOutCode"/>
    <exclude name="Squiz.Strings.EchoedStrings.HasBracket"/>
    <exclude name="Squiz.WhiteSpace.OperatorSpacing.NoSpaceBefore"/>
    <exclude name="Squiz.WhiteSpace.OperatorSpacing.NoSpaceAfter"/>
    <exclude name="Squiz.WhiteSpace.OperatorSpacing.SpacingBefore"/>
    <exclude
      name="Squiz.WhiteSpace.FunctionClosingBraceSpace.SpacingBeforeClose"
    />
  </rule>
  <rule ref="Zend">
    <!-- Back to my habits at Teliae with always a closing tag. -->
    <exclude name="Zend.Files.ClosingTag.NotAllowed"/>
    <exclude
      name="Zend.NamingConventions.ValidVariableName.NotCamelCaps"
    />
  </rule>

  <rule ref="Generic.Arrays.ArrayIndent">
    <properties>
      <property name="indent" value="2" />
    </properties>
  </rule>
  <rule ref="Generic.Files.LineLength">
    <properties>
      <property name="lineLimit" value="75"/>
      <property name="absoluteLineLimit" value="75"/>
    </properties>
  </rule>
  <rule ref="Generic.Formatting.SpaceAfterNot">
    <properties>
      <property name="spacing" value="0" />
    </properties>
  </rule>
  <rule ref="Generic.Functions.OpeningFunctionBraceKernighanRitchie">
    <properties>
      <property name="checkFunctions" value="true"/>
      <property name="checkClosures" value="true"/>
    </properties>
  </rule>
  <rule ref="Generic.Metrics.CyclomaticComplexity">
    <properties>
      <property name="complexity" value="20" />
      <property name="absoluteComplexity" value="40" />
    </properties>
  </rule>
  <rule ref="Generic.Strings.UnnecessaryStringConcat">
    <properties>
      <property name="allowMultiline" value="true" />
    </properties>
  </rule>
  <rule ref="Generic.WhiteSpace.ArbitraryParenthesesSpacing">
    <properties>
      <property name="ignoreNewlines" value="true" />
    </properties>
  </rule>
  <rule ref="Generic.WhiteSpace.ScopeIndent">
    <properties>
      <property name="ignoreIndentationTokens" type="array">
        <element value="T_COMMENT"/>
        <element value="T_DOC_COMMENT_OPEN_TAG"/>
      </property>
      <property name="indent" value="2"/>
    </properties>
  </rule>

  <rule ref="PEAR.Functions.FunctionCallSignature">
    <properties>
      <property name="indent" value="2"/>
    </properties>
  </rule>
  <rule ref="PEAR.Functions.FunctionDeclaration">
    <properties>
      <property name="indent" value="2"/>
    </properties>
  </rule>
  <rule ref="PEAR.WhiteSpace.ScopeIndent">
    <properties>
      <property name="ignoreIndentationTokens" type="array">
        <element value="T_COMMENT"/>
        <element value="T_DOC_COMMENT_OPEN_TAG"/>
      </property>
      <property name="indent" value="2"/>
    </properties>
  </rule>

  <rule ref="PSR2.Methods.FunctionCallSignature">
    <properties>
      <property name="indent" value="2"/>
    </properties>
  </rule>

  <rule ref="PSR12.ControlStructures.ControlStructureSpacing">
    <properties>
      <property name="indent" value="2"/>
    </properties>
  </rule>

  <rule ref="Squiz.Functions.MultiLineFunctionDeclaration">
    <properties>
      <property name="indent" value="2"/>
    </properties>
  </rule>
  <rule ref="Squiz.Strings.ConcatenationSpacing">
    <properties>
      <property name="ignoreNewlines" value="true" />
    </properties>
  </rule>
  <rule ref="Squiz.WhiteSpace.FunctionSpacing">
    <properties>
      <property name="spacing" value="3" />
      <property name="spacingBeforeFirst" value="0" />
      <property name="spacingAfterLast" value="0" />
    </properties>
  </rule>
</ruleset>
